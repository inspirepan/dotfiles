# 命令别名
alias ll="eza -l --group-directories-first --hyperlink --no-user"
alias la="eza -la --group-directories-first --hyperlink --no-user"
alias tree="tree --gitignore"
alias lg="lazygit"
alias fda="fd -a"
alias cat="bat"
alias kl="klaude"
alias pn="pnpm"
alias tailscale="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
alias jja="jjui -r 'all()'"
alias jjb="jj bookmark list --all"
alias jjd="jj diff"
alias jjl="jj log"
alias jjs="jj status"
alias jjf="jj git fetch"
alias jjnm="jj git fetch && jj new main@origin"
jjt() { jj bookmark track "${1:-main}" --remote="${2:-origin}"; }

# quick edit
alias zshrc="$EDITOR ~/.zshrc"
alias zshenv="$EDITOR ~/.zshenv.secret"
alias aliases="$EDITOR ~/.zsh_aliases"
alias cwd="pwd | tr -d '\n' | pbcopy"

# port: check what's using a port
port() { [[ -z "$1" ]] && { echo "Usage: port <number>"; return 1 }; lsof -i :"$1"; }
pid() { [[ -z "$1" ]] && { echo "Usage: pid <name>"; return 1 }; ps aux | head -1; ps aux | rg -i "$1"; }
ram() { local total=$(sysctl -n hw.memsize); ps aux -m | awk -v total="$total" 'NR<=1{next} {cmd=$11; for(i=12;i<=NF;i++) cmd=cmd" "$i; name=cmd; if(match(cmd,/\/([^\/]+)\.app\//)){name=substr(cmd,RSTART+1,RLENGTH-6)} else {split(cmd,a,"/"); name=a[length(a)]; sub(/ .*/,"",name)} mem[name]+=$4} END{for(n in mem){mb=mem[n]/100*total/1048576; if(mb>=1024) printf "%09.1f %5.1fG  %s\n", mb, mb/1024, n; else printf "%09.1f %5.0fM  %s\n", mb, mb, n}}' | sort -rn | cut -d' ' -f2- | head -${1:-20}; }

# mkdir + cd
unalias md 2>/dev/null
md() { mkdir -p "$1" && cd "$1"; }

# fd + nvim: open a single match directly, or choose when there are many.
fb() {
  [[ $# -eq 0 ]] && { echo "Usage: fb <fd-pattern> [path ...]"; return 1; }
  whence -p nvim >/dev/null 2>&1 || { echo "nvim is not installed."; return 1; }

  local -a matches
  local file choice

  while IFS= read -r -d '' file; do
    matches+=("$file")
  done < <(fd -H -t f -0 "$@")

  case ${#matches[@]} in
    0)
      echo "No files matched."
      return 1
      ;;
    1)
      nvim -RM -- "${matches[1]}"
      ;;
    *)
      if command -v fzf >/dev/null 2>&1; then
        choice=$(printf '%s\n' "${matches[@]}" | fzf \
          --prompt='fb> ' \
          --height=40% \
          --layout=reverse \
          --preview 'bat --style=numbers --color=always --line-range=:200 {}') || return $?
        [[ -n "$choice" ]] && nvim -RM -- "$choice"
      else
        echo "Matched ${#matches[@]} files:"
        select choice in "${matches[@]}"; do
          [[ -n "$choice" ]] || { echo "Invalid selection."; continue; }
          nvim -RM -- "$choice"
          break
        done
      fi
      ;;
  esac
}

# gclone: clone GitHub repo to ~/code/GITHUB/org-repo
gclone() {
  local url="$1"
  local cwd="$PWD"

  if [[ -z "$url" ]]; then
    echo "Usage: gclone <git-url>"
    return 1
  fi

  if [[ "$url" =~ github\.com[:/]+([^/]+)/([^/.]+)(\.git)?$ ]]; then
    local org="${match[1]}"
    local repo="${match[2]}"
    local dir="${org}-${repo}"

    mkdir -p "$HOME/code/GITHUB" || return 1

    if git -C "$HOME/code/GITHUB" clone "$url" "$dir"; then
      cd "$HOME/code/GITHUB/$dir" || cd "$cwd"
    else
      cd "$cwd"
      return 1
    fi
  else
    if git clone "$url"; then
      local repo_name
      repo_name="${url##*/}"
      repo_name="${repo_name%.git}"
      if [[ -d "$repo_name" ]]; then
        cd "$repo_name" || cd "$cwd"
      fi
    else
      return 1
    fi
  fi
}
